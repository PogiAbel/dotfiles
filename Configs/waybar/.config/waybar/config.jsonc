{
  "reload_style_on_change": true,
  "toggle": true,
  "layer": "top",
  "position": "top",
  "margin-top": 0,
  "margin-bottom": 0,
  "margin-left": 0,
  "margin-right": 0,
  "spacing": 0,
  "include": ["~/.config/waybar/modules.json"],
  "modules-left": ["niri/workspaces"],
  "modules-center": ["clock"],
  "modules-right": [
    "cpu",
    "battery",
    "temperature",
    "pulseaudio#microphone",
    "group/audio",
    "group/brightness",
    "bluetooth",
    "network",
  ]
}
